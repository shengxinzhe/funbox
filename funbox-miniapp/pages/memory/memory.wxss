.page {
  min-height: 100vh;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.top-bar {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.level-info {
  text-align: center;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #8888a0;
}

.value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.accent {
  color: #6c63ff;
}

.status {
  font-size: 30rpx;
  margin-bottom: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.status.memorize {
  background: rgba(108, 99, 255, 0.15);
  color: #6c63ff;
}

.status.input {
  background: rgba(39, 174, 96, 0.15);
  color: #27ae60;
}

.status.fail {
  background: rgba(231, 76, 60, 0.15);
  color: #e74c3c;
}

.status.success {
  background: rgba(39, 174, 96, 0.15);
  color: #27ae60;
}

/* Grid */
.grid {
  display: grid;
  gap: 12rpx;
  width: 600rpx;
  max-width: 100%;
}

.cell {
  aspect-ratio: 1;
  background: #1a1a2e;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.cell.highlight {
  background: #6c63ff;
}

.cell.correct {
  background: #27ae60;
}

.cell.wrong {
  background: #e74c3c;
}

.cell.reveal {
  background: rgba(108, 99, 255, 0.3);
  border: 2rpx solid #6c63ff;
}

.cell:active {
  transform: scale(0.95);
}

/* Actions */
.actions {
  margin-top: 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6c63ff, #5a52d5);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.share-btn {
  margin-top: 24rpx;
  background: rgba(108, 99, 255, 0.12);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.25);
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.share-btn::after {
  border: none;
}
