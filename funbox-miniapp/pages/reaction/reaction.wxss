.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  text-align: center;
  transition: background 0.3s;
}

.idle { background: #0a0a0f; }
.waiting { background: #c0392b; }
.ready { background: #27ae60; }
.early { background: #e67e22; }
.result { background: #0a0a0f; }

.icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 24rpx;
}

.time {
  font-size: 120rpx;
  font-weight: 800;
  color: #6c63ff;
  margin-bottom: 8rpx;
}

.rating {
  font-size: 36rpx;
  color: #8888a0;
  margin-bottom: 24rpx;
}

.best {
  font-size: 26rpx;
  color: #6c63ff;
  margin-top: 16rpx;
  padding: 12rpx 32rpx;
  background: rgba(108, 99, 255, 0.1);
  border-radius: 24rpx;
}

.share-btn {
  margin-top: 32rpx;
  background: rgba(108, 99, 255, 0.15);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.3);
  border-radius: 48rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.share-btn::after {
  border: none;
}
