.page {
  height: 100vh;
  position: relative;
}

/* Depth indicator */
.depth-indicator {
  position: fixed;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  text-align: center;
}

.depth-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #6c63ff;
  font-variant-numeric: tabular-nums;
}

.depth-label {
  font-size: 20rpx;
  color: #8888a0;
}

/* Ocean */
.ocean {
  height: 100vh;
}

.zone {
  padding: 48rpx 32rpx;
  position: relative;
}

.zone-name {
  font-size: 36rpx;
  font-weight: 700;
  opacity: 0.6;
  margin-bottom: 40rpx;
}

/* Creatures */
.creature {
  display: flex;
  align-items: flex-start;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(8px);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.creature-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.creature-info {
  flex: 1;
}

.creature-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.creature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

.creature-depth {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

/* Landmarks */
.landmark {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.landmark-line {
  width: 60rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.landmark-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-style: italic;
}

/* Bottom */
.bottom {
  background: #020204;
  padding: 80rpx 32rpx;
  text-align: center;
}

.bottom-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.bottom-text {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.bottom-sub {
  font-size: 28rpx;
  color: #8888a0;
}

.share-btn {
  margin-top: 32rpx;
  background: rgba(108, 99, 255, 0.15);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.3);
  border-radius: 48rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.share-btn::after {
  border: none;
}
