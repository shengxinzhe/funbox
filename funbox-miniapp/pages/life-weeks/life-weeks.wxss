.page {
  min-height: 100vh;
  padding: 32rpx;
}

/* Input section */
.input-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  text-align: center;
}

.icon { font-size: 100rpx; margin-bottom: 24rpx; }
.title { font-size: 44rpx; font-weight: 700; margin-bottom: 12rpx; }
.desc { font-size: 28rpx; color: #8888a0; margin-bottom: 48rpx; }

.btn-primary {
  background: linear-gradient(135deg, #6c63ff, #5a52d5);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
}
.btn-primary::after { border: none; }

/* Stats */
.stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat { text-align: center; }
.stat-val { font-size: 40rpx; font-weight: 700; }
.stat-label { font-size: 22rpx; color: #8888a0; margin-top: 4rpx; }
.accent { color: #6c63ff; }

/* Progress bar */
.progress-bar {
  height: 12rpx;
  background: #1a1a2e;
  border-radius: 6rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6c63ff, #ff6584);
  border-radius: 6rpx;
  transition: width 0.5s;
}

/* Grid */
.grid-scroll {
  max-height: 800rpx;
}

.grid {
  padding: 8rpx 0;
}

.row {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.age-label {
  width: 48rpx;
  font-size: 16rpx;
  color: #555;
  text-align: right;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.weeks {
  display: flex;
  flex-wrap: nowrap;
  gap: 2rpx;
}

.week {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  flex-shrink: 0;
}

.week.lived { background: #6c63ff; }
.week.current { background: #ff6584; }
.week.future { background: #1a1a2e; }

/* Legend */
.legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #8888a0;
}

.legend-item .week {
  width: 16rpx;
  height: 16rpx;
}

.share-btn {
  margin-top: 32rpx;
  background: rgba(108, 99, 255, 0.12);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.25);
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  line-height: 1.5;
}
.share-btn::after { border: none; }

.reset {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8888a0;
}
