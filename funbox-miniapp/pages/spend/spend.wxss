.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* Money bar */
.money-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: linear-gradient(135deg, #1a1a2e, #14141f);
  padding: 28rpx 32rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.money-label {
  font-size: 24rpx;
  color: #8888a0;
}

.money-amount {
  font-size: 56rpx;
  font-weight: 800;
  color: #27ae60;
  font-variant-numeric: tabular-nums;
}

.money-spent {
  font-size: 24rpx;
  color: #ff6584;
  margin-top: 4rpx;
}

/* Items */
.items {
  padding: 20rpx 32rpx;
}

.item {
  display: flex;
  align-items: center;
  background: #14141f;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}

.item-icon {
  font-size: 52rpx;
  width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
}

.item-price {
  font-size: 24rpx;
  color: #8888a0;
  margin-top: 4rpx;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.act-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  font-weight: 700;
}

.buy {
  background: #27ae60;
  color: #fff;
}

.sell {
  background: #e74c3c;
  color: #fff;
}

.disabled {
  opacity: 0.3;
}

.item-qty {
  min-width: 48rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* Receipt */
.receipt {
  margin: 32rpx;
  background: #14141f;
  border-radius: 20rpx;
  padding: 32rpx;
}

.receipt-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  text-align: center;
}

.receipt-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #8888a0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.receipt-total {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #ff6584;
}

.share-btn {
  margin-top: 24rpx;
  background: rgba(108, 99, 255, 0.12);
  color: #6c63ff;
  border: 1rpx solid rgba(108, 99, 255, 0.25);
  border-radius: 48rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.share-btn::after {
  border: none;
}
